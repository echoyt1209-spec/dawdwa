-- ========== TELEPORT TAB ==========
local TeleportTab = Window:CreateTab("Teleports", 4483362458)

local TeleportSection = TeleportTab:CreateSection("Quick Teleports")

-- Get all spawn locations
local function getSpawnLocations()
    local spawns = {}
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("SpawnLocation") or obj.Name:lower():find("spawn") then
            table.insert(spawns, obj)
        end
    end
    return spawns
end

-- Teleport to random spawn
TeleportTab:CreateButton({
    Name = "Teleport to Random Spawn",
    Callback = function()
        local spawns = getSpawnLocations()
        if #spawns > 0 and hrp and hrp.Parent then
            local randomSpawn = spawns[math.random(1, #spawns)]
            if randomSpawn:IsA("BasePart") then
                hrp.CFrame = randomSpawn.CFrame * CFrame.new(0, 5, 0)
            elseif randomSpawn:IsA("Model") then
                local primary = randomSpawn.PrimaryPart or randomSpawn:FindFirstChildWhichIsA("BasePart")
                if primary then
                    hrp.CFrame = primary.CFrame * CFrame.new(0, 5, 0)
                end
            end
            Rayfield:Notify({
                Title = "Teleported",
                Content = "Teleported to random spawn",
                Duration = 2,
                Image = 4483362458,
            })
        end
    end,
})

-- Teleport to nearest player
TeleportTab:CreateButton({
    Name = "Teleport to Nearest Player",
    Callback = function()
        if not hrp or not hrp.Parent then return end
        
        local nearestPlayer = nil
        local nearestDistance = math.huge
        
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= plr and player.Character then
                local targetHRP = player.Character:FindFirstChild("HumanoidRootPart")
                if targetHRP then
                    local distance = (hrp.Position - targetHRP.Position).Magnitude
                    if distance < nearestDistance then
                        nearestDistance = distance
                        nearestPlayer = player
                    end
                end
            end
        end
        
        if nearestPlayer and nearestPlayer.Character then
            local targetHRP = nearestPlayer.Character:FindFirstChild("HumanoidRootPart")
            if targetHRP then
                hrp.CFrame = targetHRP.CFrame * CFrame.new(0, 0, 3)
                Rayfield:Notify({
                    Title = "Teleported",
                    Content = "Teleported to " .. nearestPlayer.Name,
                    Duration = 2,
                    Image = 4483362458,
                })
            end
        end
    end,
})

