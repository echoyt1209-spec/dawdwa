-- ── UTILITY ────────────────────────────────────────────────────────────
local function getChar()     return LP.Character or LP.CharacterAdded:Wait() end
local function getHum()      local c=getChar() return c and c:FindFirstChildOfClass("Humanoid") end
local function getHRP()      local c=getChar() return c and c:FindFirstChild("HumanoidRootPart") end
local function getOpponent()
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=LP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then return p end
    end
end

-- ── STEAL REMOTE ───────────────────────────────────────────────────────
local StealRemote
local function findStealRemote()
    local roots={game:GetService("ReplicatedStorage"),LP.PlayerGui,getChar()}
    for _,root in ipairs(roots) do
        if root then
            for _,d in ipairs(root:GetDescendants()) do
                if d:IsA("RemoteEvent") or d:IsA("RemoteFunction") then
                    local n=d.Name:lower()
                    if n:find("steal") or n:find("grab") or n:find("interact") or n:find("collect") then
                        StealRemote=d return d
                    end
                end
            end
        end
    end
end

local function fireGrab(target)
    if not StealRemote then findStealRemote() end
    if not StealRemote then return end
    if StealRemote:IsA("RemoteEvent") then
        pcall(function() StealRemote:FireServer(target,"steal",tick()) end)
        pcall(function() StealRemote:FireServer("Steal",target) end)
    else
        pcall(function() StealRemote:InvokeServer(target,"steal") end)
    end
end

-- ── SPEED ──────────────────────────────────────────────────────────────
local speedConn
local function applySpeed(on)
    if speedConn then speedConn:Disconnect() speedConn=nil end
    if on then
        speedConn=RS.Heartbeat:Connect(function()
            local h=getHum() if h then h.WalkSpeed=Config.SpeedValue end
        end)
    else local h=getHum() if h then h.WalkSpeed=16 end end
end

-- ── FOV ────────────────────────────────────────────────────────────────
local fovConn
local function applyFOV(on)
    if fovConn then fovConn:Disconnect() fovConn=nil end
    if on then
        fovConn=RS.Heartbeat:Connect(function() Camera.FieldOfView=Config.FOVValue end)
    else Camera.FieldOfView=70 end
end

-- ── JUMP HEIGHT ────────────────────────────────────────────────────────
local jumpConn
local function applyJumpHeight(on)
    if jumpConn then jumpConn:Disconnect() jumpConn=nil end
    if on then
        jumpConn=RS.Heartbeat:Connect(function()
            local h=getHum()
            if h then h.JumpPower=Config.JumpHeightValue h.UseJumpPower=true end
        end)
    else local h=getHum() if h then h.JumpPower=50 end end
end

-- ── INFINITE JUMP ──────────────────────────────────────────────────────
local infJumpConn
local function applyInfiniteJump(on)
    if infJumpConn then infJumpConn:Disconnect() infJumpConn=nil end
    if on then
        infJumpConn=UIS.JumpRequest:Connect(function()
            local h=getHum() if h then h:ChangeState(Enum.HumanoidStateType.Jumping) end
        end)
    end
end

-- ── AUTO FLOAT ─────────────────────────────────────────────────────────
local floatBP,floatConn
local function isHoldingBrainrot()
    local c=getChar() if not c then return false end
    for _,v in ipairs(c:GetDescendants()) do
        local n=v.Name:lower()
        if n:find("brainrot") or n:find("stolen") or n:find("carry") then return true end
    end
    local t=c:FindFirstChildOfClass("Tool")
    if t then local n=t.Name:lower() if n:find("brainrot") or n:find("steal") then return true end end
    return false
end
local function applyFloat(on)
    if floatConn then floatConn:Disconnect() floatConn=nil end
    if floatBP then floatBP:Destroy() floatBP=nil end
    if not on then return end
    floatConn=RS.Heartbeat:Connect(function()
        local hrp=getHRP() if not hrp then return end
        if isHoldingBrainrot() then
            if not floatBP or not floatBP.Parent then
                floatBP=Instance.new("BodyPosition")
                floatBP.MaxForce=Vector3.new(0,math.huge,0)
                floatBP.D=1000 floatBP.P=10000 floatBP.Parent=hrp
            end
            local p=hrp.Position
            floatBP.Position=Vector3.new(p.X,p.Y+Config.FloatHeight,p.Z)
        else
            if floatBP and floatBP.Parent then floatBP:Destroy() floatBP=nil end
        end
    end)
end

-- ── AUTO GRAB ──────────────────────────────────────────────────────────
local autoGrabConn
local function applyAutoGrab(on)
    if autoGrabConn then autoGrabConn:Disconnect() autoGrabConn=nil end
    if not on then return end
    findStealRemote()
    autoGrabConn=RS.Heartbeat:Connect(function()
        if not Config.AutoGrab then return end
        local hrp=getHRP() if not hrp then return end
        for _,obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") then
                local n=obj.Name:lower()
                if n:find("brainrot") or n:find("steal") or n:find("grab") then
                    if (obj.Position-hrp.Position).Magnitude<15 then fireGrab(obj) end
                end
            end
        end
        for _,pp in ipairs(workspace:GetDescendants()) do
            if pp:IsA("ProximityPrompt") then
                local dist=999
                if pp.Parent and pp.Parent:IsA("BasePart") then
                    dist=(pp.Parent.Position-hrp.Position).Magnitude
                end
                if dist<pp.MaxActivationDistance+5 then
                    pp.HoldDuration=0
                    pcall(function() fireproximityprompt(pp) end)
                end
            end
        end
    end)
end

-- ── AUTO PLAY ──────────────────────────────────────────────────────────
local autoPlayThread
local function applyAutoPlay(on)
    if autoPlayThread then task.cancel(autoPlayThread) autoPlayThread=nil end
    if not on then return end
    autoPlayThread=task.spawn(function()
        while Config.AutoPlay do
            local hum=getHum() local hrp=getHRP()
            if hum and hrp then
                local opp=getOpponent()
                if opp and opp.Character and opp.Character:FindFirstChild("HumanoidRootPart") then
                    hum:MoveTo(opp.Character.HumanoidRootPart.Position)
                    hum.MoveToFinished:Wait()
                    task.wait(0.1) fireGrab(opp) task.wait(0.3)
                    if isHoldingBrainrot() then
                        for _,obj in ipairs(workspace:GetDescendants()) do
                            if obj:IsA("BasePart") then
                                local n=obj.Name:lower()
                                if (n:find("base") or n:find("pad")) and (obj.Position-hrp.Position).Magnitude<200 then
                                    hum:MoveTo(obj.Position) hum.MoveToFinished:Wait() break
                                end
                            end
                        end
                    end
                end
            end
            task.wait(0.5)
        end
    end)
end

