            pcall(function() h.JumpPower = 50 end)
        end
    end
end

-- ── INFINITE JUMP (FIX: правильная проверка состояния, без убийства) ───
local infJumpConn
local ijDebounce = false
local function applyInfiniteJump(on)
    if infJumpConn then infJumpConn:Disconnect() infJumpConn = nil end
    if on then
        infJumpConn = UIS.JumpRequest:Connect(function()
            if ijDebounce then return end
            local h   = getHum()
            local hrp = getHRP()
            if not h or not hrp then return end

            -- FIX: проверяем именно состояние humanoid, не velocity
            local state = h:GetState()
            -- Прыгаем только если уже в воздухе (не на земле и не умираем)
            if state == Enum.HumanoidStateType.Freefall
            or state == Enum.HumanoidStateType.Jumping then
                ijDebounce = true
                -- FIX: сбрасываем velocity вниз перед прыжком чтоб не улететь
                hrp.AssemblyLinearVelocity = Vector3.new(
                    hrp.AssemblyLinearVelocity.X,
                    0,
                    hrp.AssemblyLinearVelocity.Z
                )
                h:ChangeState(Enum.HumanoidStateType.Jumping)
                task.delay(0.3, function() ijDebounce = false end)
            end
        end)
    end
end

