-- ── AUTO FLOAT (FIX: BodyPosition deprecated → LinearVelocity) ─────────
local floatConn
local floatAttach
local floatLV
local floatTargetY

local function cleanFloat()
    if floatLV and floatLV.Parent then floatLV:Destroy() end
    if floatAttach and floatAttach.Parent then floatAttach:Destroy() end
    floatLV = nil
    floatAttach = nil
    floatTargetY = nil
end

local function applyFloat(on)
    if floatConn then floatConn:Disconnect() floatConn = nil end
    cleanFloat()
    if not on then return end

    floatConn = RS.Heartbeat:Connect(function()
        local hrp = getHRP()
        if not hrp then return end

        if isHoldingBrainrot() then
            if not floatTargetY then
                floatTargetY = hrp.Position.Y + Config.FloatHeight
            end

            -- FIX: используем LinearVelocity вместо deprecated BodyPosition
            if not floatAttach or not floatAttach.Parent then
                cleanFloat()
                floatAttach = Instance.new("Attachment")
                floatAttach.Position = Vector3.new(0, 0, 0)
                floatAttach.Parent = hrp

                floatLV = Instance.new("LinearVelocity")
                floatLV.Attachment0 = floatAttach
                floatLV.MaxForce = 1e6
                floatLV.VelocityConstraintMode = Enum.VelocityConstraintMode.Line
                floatLV.LineDirection = Vector3.new(0, 1, 0)
                floatLV.LineVelocity = 0
                floatLV.Parent = hrp
            end

            local dy = floatTargetY - hrp.Position.Y
            -- Пропорциональный контроллер: тянем вверх если ниже цели
            local targetVel = math.clamp(dy * 8, -30, 30)
            floatLV.LineVelocity = targetVel

            -- Гасим горизонтальное ускорение от гравитации
            hrp.AssemblyLinearVelocity = Vector3.new(
                hrp.AssemblyLinearVelocity.X,
                math.clamp(hrp.AssemblyLinearVelocity.Y, -5, 30),
                hrp.AssemblyLinearVelocity.Z
            )
        else
            floatTargetY = nil
            cleanFloat()
        end
    end)
end

-- ── AUTO GRAB (FIX: только proximity на brainrot-объектах) ─────────────
local autoGrabConn
local lastGrabTime = 0

local function applyAutoGrab(on)
    if autoGrabConn then autoGrabConn:Disconnect() autoGrabConn = nil end
    if not on then return end
    findStealRemote()

    autoGrabConn = RS.Heartbeat:Connect(function()
        if not Config.AutoGrab then return end
        local hrp = getHRP()
        if not hrp then return end

        -- throttle чтоб не спамить
        if tick() - lastGrabTime < 0.5 then return end

        -- FIX: ищем объекты только с именем brainrot, не всё подряд
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") or obj:IsA("Model") then
                local n = obj.Name:lower()
                if n:find("brainrot") or n:find("stolen") then
                    local pos = obj:IsA("Model")
                        and (obj.PrimaryPart and obj.PrimaryPart.Position or Vector3.new())
                        or obj.Position
                    if (pos - hrp.Position).Magnitude < 25 then
                        fireGrab(obj)
                        lastGrabTime = tick()
                    end
                end
            end
        end

        -- Противник с brainrot
        local opp = getOpponent()
        if opp and opp.Character then
            local oppHRP = opp.Character:FindFirstChild("HumanoidRootPart")
            if oppHRP and (oppHRP.Position - hrp.Position).Magnitude < 15 then
                -- Проверяем что у него есть brainrot
                local oppHasBrainrot = false
                for _, v in ipairs(opp.Character:GetDescendants()) do
                    if v.Name:lower():find("brainrot") then
                        oppHasBrainrot = true
                        break
                    end
                end
                if oppHasBrainrot then
                    fireGrab(opp)
                    fireGrab(opp.Character)
                    fireGrab(oppHRP)
                    lastGrabTime = tick()
                end
            end
        end
    end)
end

-- ── FIND BASE PAD ──────────────────────────────────────────────────────
local function findBasePad(side)
    local hrp = getHRP()
    if not hrp then return nil end
    local best, bestDist = nil, math.huge
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") then
            local n = obj.Name:lower()
            if n:find("base") or n:find("pad") or n:find("zone") or n:find("goal") then
                local dx = obj.Position.X - hrp.Position.X
                local valid = (side == "left" and dx < 0) or (side == "right" and dx > 0)
                if valid then
                    local d = (obj.Position - hrp.Position).Magnitude
                    if d < bestDist then bestDist = d best = obj end
                end
            end
        end
    end
    return best
end

