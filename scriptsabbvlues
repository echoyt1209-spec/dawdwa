-- Blues Hub | Steal a Brainrot
-- Using Rayfield UI Library

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
    Name = "Blues Hub | Steal a Brainrot",
    LoadingTitle = "Blues Hub Loading...",
    LoadingSubtitle = "by Blues",
    ConfigurationSaving = {
        Enabled = true,
        FolderName = "BluesHub",
        FileName = "StealBrainrot"
    },
    Discord = {
        Enabled = false,
        Invite = "",
        RememberJoins = true
    },
    KeySystem = false
})

-- Services
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local plr = Players.LocalPlayer
local char = plr.Character or plr.CharacterAdded:Wait()
local hum = char:WaitForChild("Humanoid")
local hrp = char:WaitForChild("HumanoidRootPart")

-- Update character on respawn
plr.CharacterAdded:Connect(function(newChar)
    char = newChar
    hum = newChar:WaitForChild("Humanoid")
    hrp = newChar:WaitForChild("HumanoidRootPart")
end)

-- Variables
local connections = {}
local infJumpEnabled = false
local lastJumpTime = 0
local walkSpeed = 16
local jumpPower = 50
local floatEnabled = false
local floatTime = 0
local autoGrabEnabled = false
local antiRagdollEnabled = false
local autoFarmEnabled = false
local espEnabled = false
local fullbrightEnabled = false

-- ========== MAIN TAB ==========
local MainTab = Window:CreateTab("Main", 4483362458)

local MovementSection = MainTab:CreateSection("Movement")

-- Infinite Jump
MainTab:CreateToggle({
    Name = "Infinite Jump",
    CurrentValue = false,
    Flag = "InfJump",
    Callback = function(Value)
        infJumpEnabled = Value
    end,
})

-- Inf Jump Handler
UserInputService.JumpRequest:Connect(function()
    if infJumpEnabled and hum and hum.Parent then
        local currentTime = tick()
        -- Ground check to prevent death
        local ray = Ray.new(hrp.Position, Vector3.new(0, -4, 0))
        local hit = workspace:FindPartOnRayWithIgnoreList(ray, {char})
        
        if hit or (currentTime - lastJumpTime) > 0.4 then
            hum:ChangeState(Enum.HumanoidStateType.Jumping)
            lastJumpTime = currentTime
        end
    end
end)

-- WalkSpeed Slider
MainTab:CreateSlider({
    Name = "WalkSpeed",
    Range = {16, 200},
    Increment = 1,
    CurrentValue = 16,
    Flag = "WalkSpeed",
    Callback = function(Value)
        walkSpeed = Value
    end,
})

connections.walkSpeed = RunService.Heartbeat:Connect(function()
    if hum and hum.Parent then
        hum.WalkSpeed = walkSpeed
    end
end)

-- JumpPower Slider
MainTab:CreateSlider({
    Name = "JumpPower",
    Range = {50, 150},
    Increment = 1,
    CurrentValue = 50,
    Flag = "JumpPower",
    Callback = function(Value)
        jumpPower = Value
    end,
})

connections.jumpPower = RunService.Heartbeat:Connect(function()
    if hum and hum.Parent then
        hum.JumpPower = jumpPower
    end
end)

-- Gentle Float
MainTab:CreateToggle({
    Name = "Gentle Float",
    CurrentValue = false,
    Flag = "Float",
    Callback = function(Value)
        floatEnabled = Value
        floatTime = 0
    end,
})

connections.float = RunService.Heartbeat:Connect(function(dt)
    if floatEnabled and hrp and hrp.Parent then
        floatTime = floatTime + dt
        hrp.Velocity = Vector3.new(hrp.Velocity.X, math.sin(floatTime * 1.5) * 3, hrp.Velocity.Z)
    end
end)

local CombatSection = MainTab:CreateSection("Combat")

-- Anti Ragdoll
MainTab:CreateToggle({
    Name = "Anti Ragdoll",
    CurrentValue = false,
    Flag = "AntiRagdoll",
    Callback = function(Value)
        antiRagdollEnabled = Value
    end,
})

connections.antiRagdoll = hum.StateChanged:Connect(function(old, new)
    if antiRagdollEnabled then
        if new == Enum.HumanoidStateType.FallingDown or 
           new == Enum.HumanoidStateType.Ragdoll or
           new == Enum.HumanoidStateType.PlatformStanding then
            hum:ChangeState(Enum.HumanoidStateType.Running)
        end
    end
end)

-- ========== AUTO FARM TAB ==========
local FarmTab = Window:CreateTab("Auto Farm", 4483362458)

local FarmSection = FarmTab:CreateSection("Collection")

-- Auto Grab
FarmTab:CreateToggle({
    Name = "Auto Grab Items",
    CurrentValue = false,
    Flag = "AutoGrab",
    Callback = function(Value)
        autoGrabEnabled = Value
    end,
})

connections.autoGrab = RunService.Heartbeat:Connect(function()
    if autoGrabEnabled and hrp and hrp.Parent then
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("ProximityPrompt") and obj.Enabled then
                local parent = obj.Parent
                if parent and parent:IsA("BasePart") then
                    local distance = (hrp.Position - parent.Position).Magnitude
                    
                    if distance <= obj.MaxActivationDistance then
                        -- Try multiple methods
                        pcall(function()
                            fireproximityprompt(obj, 0)
                        end)
                        
                        pcall(function()
                            obj:InputHoldBegin()
                            if obj.HoldDuration > 0 then
                                task.wait(obj.HoldDuration)
                            end
                            obj:InputHoldEnd()
                        end)
                    end
                end
            end
        end
        task.wait(0.2)
    end
end)

-- Auto Farm Loop
FarmTab:CreateToggle({
    Name = "Auto Farm (Teleport to Items)",
    CurrentValue = false,
    Flag = "AutoFarm",
    Callback = function(Value)
        autoFarmEnabled = Value
    end,
})

connections.autoFarm = RunService.Heartbeat:Connect(function()
    if autoFarmEnabled and hrp and hrp.Parent then
        -- Find closest collectable item
        local closestItem = nil
        local closestDistance = math.huge
        
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("ProximityPrompt") and obj.Enabled then
                local parent = obj.Parent
                if parent and parent:IsA("BasePart") then
                    local distance = (hrp.Position - parent.Position).Magnitude
                    if distance < closestDistance then
                        closestDistance = distance
                        closestItem = {prompt = obj, part = parent}
                    end
                end
            end
        end
        
        -- Teleport to closest item
        if closestItem and closestDistance > 5 then
            hrp.CFrame = closestItem.part.CFrame * CFrame.new(0, 3, 0)
            task.wait(0.1)
            
            -- Grab it
            pcall(function()
                fireproximityprompt(closestItem.prompt, 0)
            end)
            pcall(function()
                closestItem.prompt:InputHoldBegin()
                if closestItem.prompt.HoldDuration > 0 then
                    task.wait(closestItem.prompt.HoldDuration)
                end
                closestItem.prompt:InputHoldEnd()
            end)
        end
        
        task.wait(0.5)
    end
end)

-- ========== VISUAL TAB ==========
local VisualTab = Window:CreateTab("Visuals", 4483362458)

local VisualSection = VisualTab:CreateSection("ESP & Visuals")

-- Player ESP
VisualTab:CreateToggle({
    Name = "Player ESP",
    CurrentValue = false,
    Flag = "ESP",
    Callback = function(Value)
        espEnabled = Value
        
        if Value then
            -- Create ESP for all players
            for _, player in pairs(Players:GetPlayers()) do
                if player ~= plr and player.Character then
                    local char = player.Character
                    local hrp = char:FindFirstChild("HumanoidRootPart")
                    
                    if hrp and not hrp:FindFirstChild("BluesESP") then
                        local billboard = Instance.new("BillboardGui")
                        billboard.Name = "BluesESP"
                        billboard.Adornee = hrp
                        billboard.Size = UDim2.new(0, 100, 0, 50)
                        billboard.StudsOffset = Vector3.new(0, 3, 0)
                        billboard.AlwaysOnTop = true
                        billboard.Parent = hrp
                        
                        local nameLabel = Instance.new("TextLabel")
                        nameLabel.Size = UDim2.new(1, 0, 0.5, 0)
                        nameLabel.BackgroundTransparency = 1
                        nameLabel.Text = player.Name
                        nameLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
                        nameLabel.TextStrokeTransparency = 0.5
                        nameLabel.Font = Enum.Font.GothamBold
                        nameLabel.TextSize = 14
                        nameLabel.Parent = billboard
                        
                        local distLabel = Instance.new("TextLabel")
                        distLabel.Size = UDim2.new(1, 0, 0.5, 0)
                        distLabel.Position = UDim2.new(0, 0, 0.5, 0)
                        distLabel.BackgroundTransparency = 1
                        distLabel.TextColor3 = Color3.fromRGB(150, 150, 255)
                        distLabel.TextStrokeTransparency = 0.5
                        distLabel.Font = Enum.Font.Gotham
                        distLabel.TextSize = 12
                        distLabel.Parent = billboard
                        
                        -- Update distance
                        RunService.Heartbeat:Connect(function()
                            if hrp and hrp.Parent and char and char.Parent then
                                local myHRP = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
                                if myHRP then
                                    local dist = math.floor((myHRP.Position - hrp.Position).Magnitude)
                                    distLabel.Text = tostring(dist) .. " studs"
                                end
                            end
                        end)
                    end
                end
            end
        else
            -- Remove ESP
            for _, player in pairs(Players:GetPlayers()) do
                if player.Character then
                    local hrp = player.Character:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        local esp = hrp:FindFirstChild("BluesESP")
                        if esp then esp:Destroy() end
                    end
                end
            end
        end
    end,
})

