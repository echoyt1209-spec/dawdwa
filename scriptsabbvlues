    print("[DuelsHub] === END DUMP ===")
end
dumpRemotes() -- удали после того как найдёшь нужный remote

local function findStealRemote()
    local roots = {
        game:GetService("ReplicatedStorage"),
        game:GetService("ReplicatedFirst"),
        LP.PlayerGui,
        getChar(),
        workspace,
    }
    for _, root in ipairs(roots) do
        if root then
            for _, d in ipairs(root:GetDescendants()) do
                if d:IsA("RemoteEvent") or d:IsA("RemoteFunction") then
                    local n = d.Name:lower()
                    -- FIX: расширили список паттернов
                    if n:find("steal") or n:find("grab") or n:find("interact")
                    or n:find("collect") or n:find("pick") or n:find("take")
                    or n:find("brainrot") or n:find("action") then
                        StealRemote = d
                        print("[DuelsHub] Found remote: " .. d:GetFullName())
                        return d
                    end
                end
            end
        end
    end
end

local function fireGrab(target)
    if not StealRemote then findStealRemote() end

    -- FIX: ProximityPrompt только на brainrot-объектах, не на всём подряд
    local function tryProximity(obj)
        if not obj then return end
        for _, pp in ipairs(obj:GetDescendants()) do
            if pp:IsA("ProximityPrompt") then
                pp.HoldDuration = 0
                pcall(function() fireproximityprompt(pp) end)
                if syn and syn.fireproximityprompt then
                    pcall(function() syn.fireproximityprompt(pp) end)
                end
            end
        end
        for _, cd in ipairs(obj:GetDescendants()) do
            if cd:IsA("ClickDetector") then
                pcall(function() fireclickdetector(cd) end)
            end
        end
    end

    if StealRemote then
        if StealRemote:IsA("RemoteEvent") then
            -- Пробуем разные сигнатуры
            pcall(function() StealRemote:FireServer(target) end)
            pcall(function() StealRemote:FireServer(target, "steal", tick()) end)
            pcall(function() StealRemote:FireServer("Steal", target) end)
            pcall(function() StealRemote:FireServer() end)
        else
            pcall(function() StealRemote:InvokeServer(target, "steal") end)
            pcall(function() StealRemote:InvokeServer(target) end)
        end
    end

    if target then
        tryProximity(target)
        -- Если target это Player или Character
        if target:IsA("Model") then
            for _, part in ipairs(target:GetChildren()) do
                if part:IsA("BasePart") then
                    tryProximity(part)
                end
            end
        end
    end
end

-- ── SPEED (FIX: BodyVelocity как fallback если WalkSpeed ресетится) ────
local speedConn
local function applySpeed(on)
    if speedConn then speedConn:Disconnect() speedConn = nil end
    if on then
        speedConn = RS.Heartbeat:Connect(function()
            local h = getHum()
            if not h then return end
            if not isHoldingBrainrot() then
                -- Ставим каждый тик — если сервер ресетит, мы быстрее
                h.WalkSpeed = Config.SpeedValue
            end
        end)
    else
        local h = getHum()
        if h then h.WalkSpeed = 16 end
    end
end

