-- ── JUMP HEIGHT ────────────────────────────────────────────────────────
local jumpConn
local function applyJumpHeight(on)
    if jumpConn then jumpConn:Disconnect() jumpConn = nil end
    if on then
        jumpConn = RS.Heartbeat:Connect(function()
            local h = getHum()
            if not h then return end
            if not isHoldingBrainrot() then
                h.JumpHeight = Config.JumpHeightValue  -- FIX: JumpHeight вместо JumpPower (новый API)
                -- Fallback для старого API
                pcall(function()
                    h.JumpPower = Config.JumpHeightValue
                    h.UseJumpPower = true
                end)
            end
        end)
    else
        local h = getHum()
        if h then
