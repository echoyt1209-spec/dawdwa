-- ── AUTO PLAY ──────────────────────────────────────────────────────────
local autoPlayThread
local function applyAutoPlay(on)
    if autoPlayThread then task.cancel(autoPlayThread) autoPlayThread = nil end
    removeSideGui()
    Config.AutoPlaySide = nil
    if not on then return end
    showSideGui()

    autoPlayThread = task.spawn(function()
        local t0 = tick()
        while not Config.AutoPlaySide and (tick() - t0) < 30 do task.wait(0.2) end
        if not Config.AutoPlaySide then Config.AutoPlay = false return end

        while Config.AutoPlay do
            local hum = getHum()
            local hrp = getHRP()
            if hum and hrp then
                if not isHoldingBrainrot() then
                    local opp = getOpponent()
                    if opp and opp.Character and opp.Character:FindFirstChild("HumanoidRootPart") then
                        local oppHRP = opp.Character.HumanoidRootPart
                        hum:MoveTo(oppHRP.Position)
                        local done = false
                        local conn = hum.MoveToFinished:Connect(function() done = true end)
                        local t1 = tick()
                        while not done and (tick() - t1) < 5 do task.wait(0.1) end
                        conn:Disconnect()
                        task.wait(0.1)
                        fireGrab(opp)
                        fireGrab(opp.Character)
                        fireGrab(oppHRP)
                        task.wait(0.3)
                    end
                else
                    local pad = findBasePad(Config.AutoPlaySide)
                    if pad then
                        hum:MoveTo(pad.Position)
                        local done = false
                        local conn = hum.MoveToFinished:Connect(function() done = true end)
                        local t1 = tick()
                        while not done and (tick() - t1) < 10 do task.wait(0.1) end
                        conn:Disconnect()
                    end
                end
            end
            task.wait(0.5)
        end
    end)
end

