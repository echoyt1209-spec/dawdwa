-- ── UTILITY ────────────────────────────────────────────────────────────
local function getChar()  return LP.Character or LP.CharacterAdded:Wait() end
local function getHum()
    local c = getChar()
    return c and c:FindFirstChildOfClass("Humanoid")
end
local function getHRP()
    local c = getChar()
    return c and c:FindFirstChild("HumanoidRootPart")
end
local function getOpponent()
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            return p
        end
    end
end

-- ── IS HOLDING BRAINROT ────────────────────────────────────────────────
local function isHoldingBrainrot()
    local c = getChar()
    if not c then return false end
    for _, v in ipairs(c:GetDescendants()) do
        local n = v.Name:lower()
        if n:find("brainrot") or n:find("stolen") or n:find("carry") then return true end
    end
    local t = c:FindFirstChildOfClass("Tool")
    if t then
        local n = t.Name:lower()
        if n:find("brainrot") or n:find("steal") then return true end
    end
    return false
end

-- ── STEAL REMOTE (FIX: дампаем ВСЕ remotes в чат при первом запуске) ───
local StealRemote
local function dumpRemotes()
