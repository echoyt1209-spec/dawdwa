local yOffset = 0

-- Toggle button creator
local function createToggle(labelText, callback)
    local toggle = Instance.new("TextButton")
    toggle.Size = UDim2.new(1, 0, 0, 35)
    toggle.Position = UDim2.new(0, 0, 0, yOffset)
    toggle.BackgroundColor3 = Color3.fromRGB(45, 50, 60)
    toggle.Text = labelText .. ": OFF"
    toggle.TextColor3 = Color3.new(1, 1, 1)
    toggle.Font = Enum.Font.Gotham
    toggle.TextSize = 14
    toggle.BorderSizePixel = 0
    toggle.Parent = container
    
    local toggleCorner = Instance.new("UICorner")
    toggleCorner.CornerRadius = UDim.new(0, 6)
    toggleCorner.Parent = toggle
    
    local enabled = false
    
    toggle.MouseButton1Click:Connect(function()
        enabled = not enabled
        toggle.Text = labelText .. ": " .. (enabled and "ON" or "OFF")
        toggle.BackgroundColor3 = enabled and Color3.fromRGB(50, 180, 120) or Color3.fromRGB(45, 50, 60)
        callback(enabled)
    end)
    
    yOffset = yOffset + 40
    return toggle
end

-- Textbox creator
local function createTextbox(labelText, defaultValue, callback)
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.6, -5, 0, 35)
    label.Position = UDim2.new(0, 0, 0, yOffset)
    label.BackgroundColor3 = Color3.fromRGB(45, 50, 60)
    label.Text = labelText
    label.TextColor3 = Color3.new(1, 1, 1)
    label.Font = Enum.Font.Gotham
    label.TextSize = 14
    label.BorderSizePixel = 0
    label.Parent = container
    
    local labelCorner = Instance.new("UICorner")
    labelCorner.CornerRadius = UDim.new(0, 6)
    labelCorner.Parent = label
    
    local textbox = Instance.new("TextBox")
    textbox.Size = UDim2.new(0.4, -5, 0, 35)
    textbox.Position = UDim2.new(0.6, 5, 0, yOffset)
    textbox.BackgroundColor3 = Color3.fromRGB(35, 40, 50)
    textbox.Text = tostring(defaultValue)
    textbox.TextColor3 = Color3.new(1, 1, 1)
    textbox.Font = Enum.Font.Gotham
    textbox.TextSize = 14
    textbox.BorderSizePixel = 0
    textbox.ClearTextOnFocus = false
    textbox.Parent = container
    
    local textboxCorner = Instance.new("UICorner")
    textboxCorner.CornerRadius = UDim.new(0, 6)
    textboxCorner.Parent = textbox
    
    textbox.FocusLost:Connect(function()
        local value = tonumber(textbox.Text)
        if value then
            callback(value)
        else
            textbox.Text = tostring(defaultValue)
        end
    end)
    
    yOffset = yOffset + 40
end

