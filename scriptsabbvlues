local Config = {
    AutoGrab          = false,
    SpeedEnabled      = false,
    SpeedValue        = 24,
    FOVEnabled        = false,
    FOVValue          = 100,
    JumpHeightEnabled = false,
    JumpHeightValue   = 60,
    InfiniteJump      = false,
