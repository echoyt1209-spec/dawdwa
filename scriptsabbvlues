-- ── DRAGGABLE ──────────────────────────────────────────
local dragOrigin, frameOrigin
TitleBar.InputBegan:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1
    or inp.UserInputType == Enum.UserInputType.Touch then
        dragOrigin  = inp.Position
        frameOrigin = Main.Position
    end
end)
UIS.InputChanged:Connect(function(inp)
    if not dragOrigin then return end
    if inp.UserInputType == Enum.UserInputType.MouseMovement
    or inp.UserInputType == Enum.UserInputType.Touch then
        local d = inp.Position - dragOrigin
        Main.Position = UDim2.new(
            frameOrigin.X.Scale, frameOrigin.X.Offset + d.X,
            frameOrigin.Y.Scale, frameOrigin.Y.Offset + d.Y
        )
    end
end)
UIS.InputEnded:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1
    or inp.UserInputType == Enum.UserInputType.Touch then
        dragOrigin = nil
    end
end)

-- ── TOGGLE KEYBIND ─────────────────────────────────────
UIS.InputBegan:Connect(function(inp, gpe)
    if gpe then return end
    if inp.KeyCode == Enum.KeyCode.RightShift then
        Main.Visible = not Main.Visible
    end
end)

