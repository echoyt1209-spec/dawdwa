-- Float (reduced)
local floating = false
local floatTime = 0

makeToggle("Gentle Float", function(state)
    floating = state
    floatTime = 0
end)

RunService.Heartbeat:Connect(function(dt)
    if floating and hrp and hrp.Parent then
        floatTime = floatTime + dt
        hrp.Velocity = Vector3.new(hrp.Velocity.X, math.sin(floatTime * 1.5) * 2, hrp.Velocity.Z)
    end
end)

-- Auto Grab
local grabbing = false

makeToggle("Auto Grab", function(state)
    grabbing = state
end)

RunService.Heartbeat:Connect(function()
    if grabbing and hrp and hrp.Parent then
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("ProximityPrompt") and obj.Enabled then
                local parent = obj.Parent
                if parent and parent:IsA("BasePart") then
                    local dist = (hrp.Position - parent.Position).Magnitude
                    if dist <= obj.MaxActivationDistance then
                        pcall(function()
                            obj:InputHoldBegin()
                            if obj.HoldDuration > 0 then
                                task.wait(obj.HoldDuration)
                            end
                            obj:InputHoldEnd()
                        end)
                    end
                end
            end
        end
        task.wait(0.3)
    end
end)

-- Anti Ragdoll
local antiRag = false

makeToggle("Anti Ragdoll", function(state)
    antiRag = state
end)

hum.StateChanged:Connect(function(old, new)
    if antiRag then
        if new == Enum.HumanoidStateType.FallingDown or 
           new == Enum.HumanoidStateType.Ragdoll or
           new == Enum.HumanoidStateType.PlatformStanding then
            hum:ChangeState(Enum.HumanoidStateType.Running)
        end
    end
end)
