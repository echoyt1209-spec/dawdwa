-- Anti Ragdoll
local antiRagdollEnabled = false

createToggle("Anti Ragdoll", function(state)
    antiRagdollEnabled = state
end)

local antiRagdollConnection = hum.StateChanged:Connect(function(oldState, newState)
    if antiRagdollEnabled then
        if newState == Enum.HumanoidStateType.FallingDown or 
           newState == Enum.HumanoidStateType.Ragdoll or
           newState == Enum.HumanoidStateType.PlatformStanding then
            hum:ChangeState(Enum.HumanoidStateType.Running)
        end
    end
end)

-- Lagback Nearest Player
local lagbackEnabled = false

createToggle("Lagback Nearest", function(state)
    lagbackEnabled = state
end)

local function getNearestPlayer()
    if not hrp or not hrp.Parent then return nil end
    
    local nearestPlayer = nil
    local shortestDistance = math.huge
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= plr and player.Character then
            local targetHRP = player.Character:FindFirstChild("HumanoidRootPart")
            if targetHRP then
                local distance = (hrp.Position - targetHRP.Position).Magnitude
                if distance < shortestDistance then
                    shortestDistance = distance
                    nearestPlayer = player
                end
            end
        end
    end
    
    return nearestPlayer
end

local lagbackConnection = RunService.Heartbeat:Connect(function()
    if lagbackEnabled then
        local target = getNearestPlayer()
        if target and target.Character then
            local targetHRP = target.Character:FindFirstChild("HumanoidRootPart")
            if targetHRP then
                -- Universal lagback methods (work without network ownership)
                pcall(function()
                    targetHRP.Velocity = Vector3.new(
                        math.random(-400, 400),
                        math.random(-400, 400),
                        math.random(-400, 400)
                    )
                end)
                
                pcall(function()
                    targetHRP.AssemblyLinearVelocity = Vector3.new(
                        math.random(-500, 500),
                        math.random(-500, 500),
                        math.random(-500, 500)
                    )
                end)
                
                pcall(function()
                    local currentCFrame = targetHRP.CFrame
                    targetHRP.CFrame = currentCFrame * CFrame.new(
                        math.random(-2, 2),
                        math.random(-2, 2),
                        math.random(-2, 2)
                    )
                end)
            end
        end
    end
end)

