-- Container
local container = Instance.new("Frame")
container.Size = UDim2.new(1, -16, 1, -55)
container.Position = UDim2.new(0, 8, 0, 47)
container.BackgroundTransparency = 1
container.Parent = main

local yPos = 0

local function makeToggle(text, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 0, 34)
    btn.Position = UDim2.new(0, 0, 0, yPos)
    btn.BackgroundColor3 = Color3.fromRGB(40, 50, 80)
    btn.Text = text .. ": OFF"
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 13
    btn.BorderSizePixel = 0
    btn.Parent = container
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 6)
    btnCorner.Parent = btn
    
    local state = false
    btn.MouseButton1Click:Connect(function()
        state = not state
        btn.Text = text .. ": " .. (state and "ON" or "OFF")
        btn.BackgroundColor3 = state and Color3.fromRGB(50, 150, 100) or Color3.fromRGB(40, 50, 80)
        callback(state)
    end)
    
    yPos = yPos + 38
end

local function makeSlider(text, default, callback)
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.58, 0, 0, 34)
    label.Position = UDim2.new(0, 0, 0, yPos)
    label.BackgroundColor3 = Color3.fromRGB(40, 50, 80)
    label.Text = text
    label.TextColor3 = Color3.new(1, 1, 1)
    label.Font = Enum.Font.Gotham
    label.TextSize = 13
    label.BorderSizePixel = 0
    label.Parent = container
    
    local labelCorner = Instance.new("UICorner")
    labelCorner.CornerRadius = UDim.new(0, 6)
    labelCorner.Parent = label
    
    local box = Instance.new("TextBox")
    box.Size = UDim2.new(0.38, 0, 0, 34)
    box.Position = UDim2.new(0.62, 0, 0, yPos)
    box.BackgroundColor3 = Color3.fromRGB(30, 40, 70)
    box.Text = tostring(default)
    box.TextColor3 = Color3.new(1, 1, 1)
    box.Font = Enum.Font.Gotham
    box.TextSize = 13
    box.BorderSizePixel = 0
    box.ClearTextOnFocus = false
    box.Parent = container
    
    local boxCorner = Instance.new("UICorner")
    boxCorner.CornerRadius = UDim.new(0, 6)
    boxCorner.Parent = box
    
    box.FocusLost:Connect(function()
        local val = tonumber(box.Text)
        if val then callback(val) end
    end)
    
    yPos = yPos + 38
end

-- FEATURES

-- Inf Jump (FIXED FOR DELTA - ground check)
local infJump = false
local lastJump = 0

makeToggle("Infinite Jump", function(state)
    infJump = state
end)

local function isGrounded()
    -- Raycast downward to check if on ground
    local ray = Ray.new(hrp.Position, Vector3.new(0, -4, 0))
    local hit = workspace:FindPartOnRayWithIgnoreList(ray, {char})
    return hit ~= nil or hum:GetState() == Enum.HumanoidStateType.Landed
end

UserInputService.JumpRequest:Connect(function()
    if infJump and hum and hum.Parent then
        local now = tick()
        -- Only jump if grounded OR 0.5 seconds passed (prevents death)
        if isGrounded() or (now - lastJump) > 0.5 then
            hum:ChangeState(Enum.HumanoidStateType.Jumping)
            lastJump = now
        end
    end
end)

