-- Steal a Brainrot | Duels Exploit Hub
-- Compatible: Delta, Solara, Fluxus, Wave
-- Paste into executor, press RightShift for toggle menu

local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")
local RS = game:GetService("RunService")
local LP = Players.LocalPlayer
local Camera = workspace.CurrentCamera

-- ============ CONFIG ============
local Config = {
    AutoGrab = false,
    SpeedEnabled = false,
    SpeedValue = 24,          -- default 16, safe range 16-28
    FOVEnabled = false,
    FOVValue = 100,            -- default 70
    JumpHeightEnabled = false,
    JumpHeightValue = 60,      -- default 50
    InfiniteJump = false,
    AutoFloat = false,
    FloatHeight = 25,
    AutoPlay = false,
}

-- ============ UTILITY ============
local function getChar()
    return LP.Character or LP.CharacterAdded:Wait()
end

local function getHumanoid()
    local ch = getChar()
    return ch and ch:FindFirstChildOfClass("Humanoid")
end

local function getHRP()
    local ch = getChar()
    return ch and ch:FindFirstChild("HumanoidRootPart")
end

local function getOpponent()
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            return p
        end
    end
    return nil
end

-- ============ FIND STEAL REMOTE ============
-- The game fires a RemoteEvent or RemoteFunction for steal interaction
-- We scan ReplicatedStorage and the character for the grab remote
local StealRemote = nil
local function findStealRemote()
    -- Common paths in Steal a Brainrot
    local paths = {
        game:GetService("ReplicatedStorage"),
        LP.PlayerGui,
        getChar(),
    }
    for _, root in ipairs(paths) do
        if root then
            for _, desc in ipairs(root:GetDescendants()) do
                if desc:IsA("RemoteEvent") or desc:IsA("RemoteFunction") then
                    local n = desc.Name:lower()
                    if n:find("steal") or n:find("grab") or n:find("interact") or n:find("collect") then
                        StealRemote = desc
                        return desc
                    end
                end
            end
        end
    end
    return nil
end

-- ============ AUTO GRAB ============
-- Fires the steal remote instantly when in range
-- Bypasses the 3s hold by sending the completion signal directly
local function fireGrab(target)
    if not StealRemote then findStealRemote() end
    if not StealRemote then return end

    if StealRemote:IsA("RemoteEvent") then
        StealRemote:FireServer(target, "steal", tick())
        -- Some versions use different arg patterns, try both
        pcall(function()
            StealRemote:FireServer("Steal", target)
        end)
    elseif StealRemote:IsA("RemoteFunction") then
        pcall(function()
            StealRemote:InvokeServer(target, "steal")
        end)
    end
end

local function getOpponentBase()
    -- Scan workspace for opponent's base/brainrot pad
    local opp = getOpponent()
    if not opp then return nil end
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj.Name:lower():find("base") or obj.Name:lower():find("pad") or obj.Name:lower():find("brainrot") then
            if obj:IsA("BasePart") then
                return obj
            end
        end
    end
    return nil
end

-- ============ SPEED CHANGER ============
local speedConn = nil
local function applySpeed(on)
    if speedConn then speedConn:Disconnect() speedConn = nil end
    if on then
        speedConn = RS.Heartbeat:Connect(function()
            local hum = getHumanoid()
            if hum then
                hum.WalkSpeed = Config.SpeedValue
            end
        end)
    else
        local hum = getHumanoid()
        if hum then hum.WalkSpeed = 16 end
    end
end

-- ============ FOV CHANGER ============
local fovConn = nil
local function applyFOV(on)
    if fovConn then fovConn:Disconnect() fovConn = nil end
    if on then
        fovConn = RS.Heartbeat:Connect(function()
            Camera.FieldOfView = Config.FOVValue
        end)
    else
        Camera.FieldOfView = 70
    end
end

-- ============ JUMP HEIGHT ============
local jumpConn = nil
local function applyJumpHeight(on)
    if jumpConn then jumpConn:Disconnect() jumpConn = nil end
    if on then
        jumpConn = RS.Heartbeat:Connect(function()
            local hum = getHumanoid()
            if hum then
                hum.JumpPower = Config.JumpHeightValue
                -- UseJumpPower might be toggled off in newer versions
                hum.UseJumpPower = true
            end
        end)
    else
        local hum = getHumanoid()
        if hum then hum.JumpPower = 50 end
    end
end

-- ============ INFINITE JUMP ============
local infJumpConn = nil
local function applyInfiniteJump(on)
    if infJumpConn then infJumpConn:Disconnect() infJumpConn = nil end
    if on then
        infJumpConn = UIS.JumpRequest:Connect(function()
            local hum = getHumanoid()
            if hum then
                hum:ChangeState(Enum.HumanoidStateType.Jumping)
            end
        end)
    end
end

-- ============ AUTO FLOAT ============
-- When holding a brainrot, sets a BodyPosition to hover
local floatBP = nil
local floatConn = nil

local function isHoldingBrainrot()
    local ch = getChar()
    if not ch then return false end
    for _, child in ipairs(ch:GetDescendants()) do
        local n = child.Name:lower()
        if n:find("brainrot") or n:find("stolen") or n:find("carry") or n:find("holding") then
            return true
        end
    end
    -- Also check if a tool/item is equipped that indicates holding
    local tool = ch:FindFirstChildOfClass("Tool")
    if tool then
        local tn = tool.Name:lower()
        if tn:find("brainrot") or tn:find("steal") then
            return true
        end
    end
    return false
end

local function applyFloat(on)
    if floatConn then floatConn:Disconnect() floatConn = nil end
    if floatBP then floatBP:Destroy() floatBP = nil end

    if on then
        floatConn = RS.Heartbeat:Connect(function()
            local hrp = getHRP()
            if not hrp then return end

            if isHoldingBrainrot() then
                if not floatBP or not floatBP.Parent then
                    floatBP = Instance.new("BodyPosition")
                    floatBP.MaxForce = Vector3.new(0, math.huge, 0)
                    floatBP.D = 1000
                    floatBP.P = 10000
                    floatBP.Parent = hrp
                end
                local pos = hrp.Position
                floatBP.Position = Vector3.new(pos.X, pos.Y + Config.FloatHeight, pos.Z)
            else
                if floatBP and floatBP.Parent then
                    floatBP:Destroy()
                    floatBP = nil
                end
            end
        end)
    end
end

-- ============ AUTO PLAY ============
-- Loops: walk to opponent base -> grab -> walk back -> score -> repeat
local autoPlayConn = nil
local function applyAutoPlay(on)
    if autoPlayConn then autoPlayConn:Disconnect() autoPlayConn = nil end
    if not on then return end

    autoPlayConn = task.spawn(function()
        while Config.AutoPlay do
            local hum = getHumanoid()
            local hrp = getHRP()
            if not hum or not hrp then task.wait(1) continue end

            -- Phase 1: Move to opponent's base area
            local oppBase = getOpponentBase()
            local opp = getOpponent()
            if opp and opp.Character and opp.Character:FindFirstChild("HumanoidRootPart") then
                local targetPos = opp.Character.HumanoidRootPart.Position
                -- If we found a base object, prefer that
                if oppBase then
                    targetPos = oppBase.Position
                end
                hum:MoveTo(targetPos)
                hum.MoveToFinished:Wait()

                -- Phase 2: Attempt grab
                task.wait(0.1)
                fireGrab(opp)
                fireGrab(oppBase)
                task.wait(0.3)

                -- Phase 3: If holding, run back to own base
                if isHoldingBrainrot() then
                    -- Find own base
                    for _, obj in ipairs(workspace:GetDescendants()) do
                        if obj:IsA("BasePart") then
                            local n = obj.Name:lower()
                            if (n:find("base") or n:find("pad")) then
                                -- Check if it belongs to us (proximity heuristic)
                                if (obj.Position - hrp.Position).Magnitude < 200 then
                                    hum:MoveTo(obj.Position)
                                    hum.MoveToFinished:Wait()
                                    break
                                end
                            end
                        end
                    end
                end
            end
            task.wait(0.5)
        end
    end)
end

-- ============ AUTO GRAB LOOP ============
local autoGrabConn = nil
local function applyAutoGrab(on)
    if autoGrabConn then autoGrabConn:Disconnect() autoGrabConn = nil end
    if not on then return end

    findStealRemote()
    autoGrabConn = RS.Heartbeat:Connect(function()
        if not Config.AutoGrab then return end
        local hrp = getHRP()
        if not hrp then return end

        -- Check proximity to stealable objects
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") then
                local n = obj.Name:lower()
                if n:find("brainrot") or n:find("steal") or n:find("grab") or n:find("interact") then
                    if (obj.Position - hrp.Position).Magnitude < 15 then
                        -- Fire grab immediately, skip hold timer
                        fireGrab(obj)
                    end
                end
            end
        end

        -- Also check ProximityPrompts and fire them instantly
        for _, pp in ipairs(workspace:GetDescendants()) do
            if pp:IsA("ProximityPrompt") then
                local dist = 999
                if pp.Parent and pp.Parent:IsA("BasePart") then
                    dist = (pp.Parent.Position - hrp.Position).Magnitude
                end
                if dist < pp.MaxActivationDistance + 5 then
                    -- Bypass hold duration
                    pp.HoldDuration = 0
                    fireproximityprompt(pp)
                end
            end
        end
    end)
end

