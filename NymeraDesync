-- [GROK-RAW] Nymera Desync v2.1 - Fixed for Delta Executor (Mobile + PC)
local uis = game:GetService("UserInputService")
local players = game:GetService("Players")
local rs = game:GetService("RunService")
local lp = players.LocalPlayer

local hooked = false
local toggleKey = Enum.KeyCode.U
local listeningForKey = false

-- GUI
local screenGui = Instance.new("ScreenGui")
screenGui.ResetOnSpawn = false
screenGui.Parent = lp:WaitForChild("PlayerGui")

local mainFrame = Instance.new("Frame")
mainFrame.Size = UDim2.new(0, 260, 0, 220)
mainFrame.Position = UDim2.new(0, 20, 0, 20)
mainFrame.BackgroundColor3 = Color3.fromRGB(8, 8, 18)
mainFrame.Active = true
mainFrame.Draggable = true
mainFrame.Parent = screenGui

local corner = Instance.new("UICorner") corner.CornerRadius = UDim.new(0, 10) corner.Parent = mainFrame
local stroke = Instance.new("UIStroke") stroke.Color = Color3.fromRGB(0, 130, 255) stroke.Thickness = 2 stroke.Parent = mainFrame

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1,0,0,45)
title.BackgroundTransparency = 1
title.Text = "NYMERA DESYNC"
title.TextColor3 = Color3.fromRGB(80, 190, 255)
title.TextSize = 19
title.Font = Enum.Font.GothamBlack
title.Parent = mainFrame

local toggleBtn = Instance.new("TextButton")
toggleBtn.Size = UDim2.new(0.9,0,0,50)
toggleBtn.Position = UDim2.new(0.05,0,0,65)
toggleBtn.BackgroundColor3 = Color3.fromRGB(20,20,35)
toggleBtn.Text = "DESYNC OFF"
toggleBtn.TextColor3 = Color3.fromRGB(200,60,60)
toggleBtn.TextSize = 16
toggleBtn.Font = Enum.Font.GothamBold
toggleBtn.Parent = mainFrame
Instance.new("UICorner", toggleBtn).CornerRadius = UDim.new(0,8)

local keybindBtn = Instance.new("TextButton")
keybindBtn.Size = UDim2.new(0.9,0,0,35)
keybindBtn.Position = UDim2.new(0.05,0,0,125)
keybindBtn.BackgroundColor3 = Color3.fromRGB(20,20,35)
keybindBtn.Text = "Keybind: [ U ]"
keybindBtn.TextColor3 = Color3.fromRGB(140,160,255)
keybindBtn.TextSize = 14
keybindBtn.Parent = mainFrame
Instance.new("UICorner", keybindBtn).CornerRadius = UDim.new(0,8)

local statusLabel = Instance.new("TextLabel")
statusLabel.Size = UDim2.new(0.9,0,0,35)
statusLabel.Position = UDim2.new(0.05,0,0,170)
statusLabel.BackgroundTransparency = 1
statusLabel.Text = "Status: Ready"
statusLabel.TextColor3 = Color3.fromRGB(100,100,140)
statusLabel.TextSize = 13
statusLabel.Parent = mainFrame

local function updateUI()
    if hooked then
        toggleBtn.Text = "DESYNC ON"
        toggleBtn.TextColor3 = Color3.fromRGB(60,220,100)
        stroke.Color = Color3.fromRGB(60,220,100)
        statusLabel.Text = "Ghost Active on Delta"
    else
        toggleBtn.Text = "DESYNC OFF"
        toggleBtn.TextColor3 = Color3.fromRGB(200,60,60)
        stroke.Color = Color3.fromRGB(0,130,255)
        statusLabel.Text = "Ghost Inactive"
    end
end

-- Simple & Reliable Desync for Delta
local function activateDesync()
    if raknet and raknet.desync then
        pcall(function()
            raknet.desync(true)
        end)
        print("[GROK-RAW] raknet.desync(true) activated")
        statusLabel.Text = "Using raknet.desync (recommended)"
    else
        statusLabel.Text = "RakNet not found - Update Delta"
        warn("[GROK-RAW] raknet.desync not available on your Delta version")
        return
    end

    hooked = true
    updateUI()
end

local function deactivateDesync()
    if raknet and raknet.desync then
        pcall(function()
            raknet.desync(false)
        end)
    end
    hooked = false
    updateUI()
end

toggleBtn.MouseButton1Click:Connect(function()
    if hooked then
        deactivateDesync()
    else
        activateDesync()
    end
end)

keybindBtn.MouseButton1Click:Connect(function()
    if listeningForKey then return end
    listeningForKey = true
    keybindBtn.Text = "Press any key..."
end)

uis.InputBegan:Connect(function(input, gp)
    if listeningForKey and input.UserInputType == Enum.UserInputType.Keyboard then
        toggleKey = input.KeyCode
        keybindBtn.Text = "Keybind: [ " .. tostring(toggleKey):gsub("Enum.KeyCode.", "") .. " ]"
        listeningForKey = false
        return
    end

    if gp or input.KeyCode ~= toggleKey then return end

    if hooked then
        deactivateDesync()
    else
        activateDesync()
    end
end)

print("[GROK-RAW] Nymera Desync v2.1 loaded on Delta. Try toggling now. If it still fails, tell me your exact Delta version.")
